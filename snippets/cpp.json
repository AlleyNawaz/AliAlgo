		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"int binarySearch(int A[], int l, int h, int key) {",
			"\twhile (l <= h) {",
			"\t\tint mid = (l + h) / 2;",
			"\t\tif (key == A[mid]) return mid;",
			"\t\telse if (key < A[mid]) h = mid - 1;",
			"\t\telse l = mid + 1;",
			"\t}",
			"\treturn -1;",
			"}",
			"",
			"int main() {",
			"\tint A[] = {2, 3, 5, 7, 10, 12, 15, 20}, n = 8;",
			"\tcout << \"Index of 10: \" << binarySearch(A, 0, n - 1, 10) << endl;",
