	"heap-max-manual": {
		"prefix": "heap-max-manual",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class MaxHeap {",
			"\tint h[100], size = 0;",
			"\tvoid heapify(int i) {",
			"\t\tint largest = i, l = 2*i+1, r = 2*i+2;",
			"\t\tif (l < size && h[l] > h[largest]) largest = l;",
			"\t\tif (r < size && h[r] > h[largest]) largest = r;",
			"\t\tif (largest != i) { int t = h[i]; h[i] = h[largest]; h[largest] = t; heapify(largest); }",
			"\t}",
			"public:",
			"\tvoid push(int x) { h[size++] = x; int i = size-1; while(i && h[(i-1)/2] < h[i]) { int t=h[i]; h[i]=h[(i-1)/2]; h[(i-1)/2]=t; i = (i-1)/2; } }",
			"\tint pop() { if(!size) return -1; int x = h[0]; h[0] = h[--size]; heapify(0); return x; }",
			"};",
			"",
			"int main() {",
			"\tMaxHeap heap; heap.push(10); heap.push(30); heap.push(20);",
			"\tcout << \"Popped: \" << heap.pop() << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Max Heap implementation (Manual)"
	},
