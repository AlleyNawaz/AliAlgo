	"ll-singular-adt": {
		"prefix": "ll-singular-adt",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tint data;",
			"\tNode *next;",
			"};",
			"",
			"class LinkedList {",
			"private:",
			"\tNode *first;",
			"public:",
			"\tLinkedList() { first = NULL; }",
			"\tLinkedList(int A[], int n) {",
			"\t\tNode *last, *t;",
			"\t\tfirst = new Node;",
			"\t\tfirst->data = A[0];",
			"\t\tfirst->next = NULL;",
			"\t\tlast = first;",
			"\t\tfor (int i = 1; i < n; i++) {",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = A[i];",
			"\t\t\tt->next = NULL;",
			"\t\t\tlast->next = t;",
			"\t\t\tlast = t;",
			"\t\t}",
			"\t}",
			"\t~LinkedList() {",
			"\t\tNode *p = first;",
			"\t\twhile (first) {",
			"\t\t\tfirst = first->next;",
			"\t\t\tdelete p;",
			"\t\t\tp = first;",
			"\t\t}",
			"\t}",
			"\tvoid display() {",
			"\t\tNode *p = first;",
			"\t\twhile (p) {",
			"\t\t\tcout << p->data << \" \";",
			"\t\t\tp = p->next;",
			"\t\t}",
			"\t\tcout << endl;",
			"\t}",
			"\tvoid insert(int index, int x) {",
			"\t\tNode *t, *p = first;",
			"\t\tif (index < 0) return;",
			"\t\tt = new Node;",
			"\t\tt->data = x;",
			"\t\tif (index == 0) {",
			"\t\t\tt->next = first;",
			"\t\t\tfirst = t;",
			"\t\t} else {",
			"\t\t\tfor (int i = 0; i < index - 1 && p; i++) p = p->next;",
			"\t\t\tif (p) {",
			"\t\t\t\tt->next = p->next;",
			"\t\t\t\tp->next = t;",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"\tint deleteNode(int index) {",
			"\t\tNode *p, *q = NULL;",
			"\t\tint x = -1;",
			"\t\tif (index == 1) {",
			"\t\t\tp = first;",
			"\t\t\tfirst = first->next;",
			"\t\t\tx = p->data;",
			"\t\t\tdelete p;",
			"\t\t} else {",
			"\t\t\tp = first;",
			"\t\t\tfor (int i = 0; i < index - 1 && p; i++) {",
			"\t\t\t\tq = p;",
			"\t\t\t\tp = p->next;",
			"\t\t\t}",
			"\t\t\tif (p) {",
			"\t\t\t\tq->next = p->next;",
			"\t\t\t\tx = p->data;",
			"\t\t\t\tdelete p;",
			"\t\t\t}",
			"\t\t}",
			"\t\treturn x;",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tint A[] = {1, 2, 3, 4, 5};",
			"\tLinkedList l(A, 5);",
			"\tl.insert(0, 10);",
			"\tl.display();",
			"\treturn 0;",
			"}"
		],
		"description": "Full Singly Linked List ADT class implementation"
	},
	"ll-circular-adt": {
		"prefix": "ll-circular-adt",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tint data;",
			"\tNode *next;",
			"};",
			"",
			"class CircularList {",
			"private:",
			"\tNode *head;",
			"public:",
			"\tCircularList() { head = NULL; }",
			"\tCircularList(int A[], int n) {",
			"\t\tNode *t, *last;",
			"\t\thead = new Node;",
			"\t\thead->data = A[0];",
			"\t\thead->next = head;",
			"\t\tlast = head;",
			"\t\tfor (int i = 1; i < n; i++) {",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = A[i];",
			"\t\t\tt->next = last->next;",
			"\t\t\tlast->next = t;",
			"\t\t\tlast = t;",
			"\t\t}",
			"\t}",
			"\tvoid display() {",
			"\t\tNode *p = head;",
			"\t\tdo {",
			"\t\t\tcout << p->data << \" \";",
			"\t\t\tp = p->next;",
			"\t\t} while (p != head);",
			"\t\tcout << endl;",
			"\t}",
			"\tvoid insert(int index, int x) {",
			"\t\tNode *t, *p = head;",
			"\t\tif (index == 0) {",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = x;",
			"\t\t\tif (head == NULL) {",
			"\t\t\t\thead = t;",
			"\t\t\t\thead->next = head;",
			"\t\t\t} else {",
			"\t\t\t\twhile (p->next != head) p = p->next;",
			"\t\t\t\tp->next = t;",
			"\t\t\t\tt->next = head;",
			"\t\t\t\thead = t;",
			"\t\t\t}",
			"\t\t} else {",
			"\t\t\tfor (int i = 0; i < index - 1; i++) p = p->next;",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = x;",
			"\t\t\tt->next = p->next;",
			"\t\t\tp->next = t;",
			"\t\t}",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tint A[] = {2, 3, 4, 5, 6};",
			"\tCircularList cl(A, 5);",
			"\tcl.insert(0, 1);",
			"\tcl.display();",
			"\treturn 0;",
			"}"
		],
		"description": "Full Circular Linked List ADT class implementation"
	},
	"ll-doubly-adt": {
		"prefix": "ll-doubly-adt",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tNode *prev;",
			"\tint data;",
			"\tNode *next;",
			"};",
			"",
			"class DoublyList {",
			"private:",
			"\tNode *first;",
			"public:",
			"\tDoublyList() { first = NULL; }",
			"\tDoublyList(int A[], int n) {",
			"\t\tNode *t, *last;",
			"\t\tfirst = new Node;",
			"\t\tfirst->data = A[0];",
			"\t\tfirst->prev = first->next = NULL;",
			"\t\tlast = first;",
			"\t\tfor (int i = 1; i < n; i++) {",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = A[i];",
			"\t\t\tt->next = last->next;",
			"\t\t\tt->prev = last;",
			"\t\t\tlast->next = t;",
			"\t\t\tlast = t;",
			"\t\t}",
			"\t}",
			"\tvoid display() {",
			"\t\tNode *p = first;",
			"\t\twhile (p) {",
			"\t\t\tcout << p->data << \" \";",
			"\t\t\tp = p->next;",
			"\t\t}",
			"\t\tcout << endl;",
			"\t}",
			"\tvoid insert(int index, int x) {",
			"\t\tNode *t, *p = first;",
			"\t\tif (index == 0) {",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = x;",
			"\t\t\tt->prev = NULL;",
			"\t\t\tt->next = first;",
			"\t\t\tfirst->prev = t;",
			"\t\t\tfirst = t;",
			"\t\t} else {",
			"\t\t\tfor (int i = 0; i < index - 1; i++) p = p->next;",
			"\t\t\tt = new Node;",
			"\t\t\tt->data = x;",
			"\t\t\tt->prev = p;",
			"\t\t\tt->next = p->next;",
			"\t\t\tif (p->next) p->next->prev = t;",
			"\t\t\tp->next = t;",
			"\t\t}",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tint A[] = {10, 20, 30, 40, 50};",
			"\tDoublyList dl(A, 5);",
			"\tdl.insert(2, 25);",
			"\tdl.display();",
			"\treturn 0;",
			"}"
		],
		"description": "Full Doubly Linked List ADT class implementation"
	},
	"stack-adt-array": {
		"prefix": "stack-adt-array",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Stack {",
			"private:",
			"\tint size;",
			"\tint top;",
			"\tint *S;",
			"public:",
			"\tStack(int size) {",
			"\t\tthis->size = size;",
			"\t\ttop = -1;",
			"\t\tS = new int[this->size];",
			"\t}",
			"\tvoid push(int x) {",
			"\t\tif (top == size - 1) cout << \"Stack Overflow\" << endl;",
			"\t\telse { top++; S[top] = x; }",
			"\t}",
			"\tint pop() {",
			"\t\tint x = -1;",
			"\t\tif (top == -1) cout << \"Stack Underflow\" << endl;",
			"\t\telse { x = S[top]; top--; }",
			"\t\treturn x;",
			"\t}",
			"\tint peek(int index) {",
			"\t\tint x = -1;",
			"\t\tif (top - index + 1 < 0) cout << \"Invalid Index\" << endl;",
			"\t\telse x = S[top - index + 1];",
			"\t\treturn x;",
			"\t}",
			"\tint stackTop() {",
			"\t\tif (top == -1) return -1;",
			"\t\treturn S[top];",
			"\t}",
			"\tint isEmpty() { return top == -1; }",
			"\tint isFull() { return top == size - 1; }",
			"};",
			"",
			"int main() {",
			"\tStack st(5);",
			"\tst.push(10); st.push(20); st.push(30);",
			"\tcout << \"Popped: \" << st.pop() << endl;",
			"\tcout << \"Top element: \" << st.stackTop() << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Stack ADT using array implementation from scratch"
	},
