	"ll-merge-sorted": {
		"prefix": "ll-merge-sorted",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* mergeSorted(Node* a, Node* b) {",
			"\tif (!a) return b; if (!b) return a;",
			"\tif (a->data < b->data) { a->next = mergeSorted(a->next, b); return a; }",
			"\telse { b->next = mergeSorted(a, b->next); return b; }",
			"}",
			"",
			"int main() {",
			"\tNode* l1 = new Node(10); l1->next = new Node(30);",
			"\tNode* l2 = new Node(20); l2->next = new Node(40);",
			"\tNode* merged = mergeSorted(l1, l2);",
			"\twhile(merged) { cout << merged->data << \" \"; merged = merged->next; }",
			"\treturn 0;",
			"}"
		],
		"description": "Merge sorted linked lists (Manual)"
	},
