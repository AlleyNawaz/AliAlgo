	"sort-quick": {
		"prefix": "sort-quick",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"int partition(int arr[], int l, int h) {",
			"\tint p=arr[h], i=l-1; ",
			"\tfor(int j=l; j<h; j++) if(arr[j]<p) { i++; int t=arr[i]; arr[i]=arr[j]; arr[j]=t; }",
			"\tint t=arr[i+1]; arr[i+1]=arr[h]; arr[h]=t; return i+1;",
			"}",
			"void quickSort(int arr[], int l, int h) {",
			"\tif(l<h){ int pi=partition(arr, l, h); quickSort(arr, l, pi-1); quickSort(arr, pi+1, h); }",
			"}",
			"",
			"int main() {",
			"\tint a[] = {10, 7, 8, 9, 1, 5}; quickSort(a, 0, 5);",
			"\tfor(int i=0; i<6; i++) cout << a[i] << \" \";",
			"\treturn 0;",
			"}"
		],
		"description": "Quick sort (Manual)"
	},
