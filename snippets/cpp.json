	"tree-insert-bst": {
		"prefix": "tree-insert-bst",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct TreeNode {",
			"\tint val; TreeNode *left, *right;",
			"\tTreeNode(int x) : val(x), left(nullptr), right(nullptr) {}",
			"};",
			"",
			"TreeNode* insertBST(TreeNode* root, int val) {",
			"\tif (!root) return new TreeNode(val);",
			"\tif (val < root->val) root->left = insertBST(root->left, val);",
			"\telse root->right = insertBST(root->right, val);",
			"\treturn root;",
			"}",
			"",
			"int main() {",
			"\tTreeNode* root = nullptr;",
			"\troot = insertBST(root, 50); insertBST(root, 30); insertBST(root, 70);",
			"\tcout << \"BST Root: \" << root->val << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Insert into BST (Manual)"
	},
