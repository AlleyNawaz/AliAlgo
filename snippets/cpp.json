	"ll-delete-tail": {
		"prefix": "ll-delete-tail",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* deleteTail(Node* head) {",
			"\tif (!head || !head->next) { delete head; return nullptr; }",
			"\tNode* temp = head;",
			"\twhile (temp->next->next) temp = temp->next;",
			"\tdelete temp->next; temp->next = nullptr;",
			"\treturn head;",
			"}",
			"",
			"int main() {",
			"\tNode* head = new Node(10); head->next = new Node(20);",
			"\thead = deleteTail(head);",
			"\tcout << \"After deleting tail, list: \" << head->data << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Delete tail of linked list (Manual)"
	},
	"ll-delete-val": {
		"prefix": "ll-delete-val",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* deleteByValue(Node* head, int val) {",
			"\tif (!head) return nullptr;",
			"\tif (head->data == val) { Node* temp = head; head = head->next; delete temp; return head; }",
			"\tNode* temp = head;",
			"\twhile (temp->next && temp->next->data != val) temp = temp->next;",
			"\tif (temp->next) { Node* toDelete = temp->next; temp->next = temp->next->next; delete toDelete; }",
			"\treturn head;",
			"}",
			"",
			"int main() {",
			"\tNode* head = new Node(10); head->next = new Node(20); head->next->next = new Node(30);",
			"\thead = deleteByValue(head, 20);",
			"\twhile(head) { cout << head->data << \" \"; head = head->next; }",
			"\treturn 0;",
			"}"
		],
		"description": "Delete by value in linked list (Manual)"
	},
	"ll-reverse": {
		"prefix": "ll-reverse",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* reverseList(Node* head) {",
			"\tNode *prev = nullptr, *curr = head, *next = nullptr;",
			"\twhile (curr) { next = curr->next; curr->next = prev; prev = curr; curr = next; }",
			"\treturn prev;",
			"}",
			"",
			"int main() {",
			"\tNode* head = new Node(1); head->next = new Node(2); head->next->next = new Node(3);",
			"\thead = reverseList(head);",
			"\twhile(head) { cout << head->data << \" \"; head = head->next; }",
			"\treturn 0;",
			"}"
		],
		"description": "Reverse linked list (Iterative)"
	},
	"ll-reverse-rec": {
		"prefix": "ll-reverse-rec",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* reverseRec(Node* head) {",
			"\tif (!head || !head->next) return head;",
			"\tNode* newHead = reverseRec(head->next);",
			"\thead->next->next = head; head->next = nullptr;",
			"\treturn newHead;",
			"}",
			"",
			"int main() {",
			"\tNode* head = new Node(1); head->next = new Node(2); head->next->next = new Node(3);",
			"\thead = reverseRec(head);",
			"\twhile(head) { cout << head->data << \" \"; head = head->next; }",
			"\treturn 0;",
			"}"
		],
		"description": "Reverse linked list (Recursive)"
	},
	"ll-detect-cycle": {
		"prefix": "ll-detect-cycle",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"bool hasCycle(Node* head) {",
			"\tNode *slow = head, *fast = head;",
			"\twhile (fast && fast->next) {",
			"\t\tslow = slow->next; fast = fast->next->next;",
			"\t\tif (slow == fast) return true;",
			"\t}",
			"\treturn false;",
			"}",
			"",
			"int main() {",
			"\tNode* head = new Node(1); head->next = new Node(2);",
			"\thead->next->next = head; ",
			"\tif (hasCycle(head)) cout << \"Cycle detected!\" << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Detect cycle in linked list (Manual)"
	},
