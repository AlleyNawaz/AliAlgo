	"queue-adt-array": {
		"prefix": "queue-adt-array",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Queue {",
			"private:",
			"\tint size;",
			"\tint front;",
			"\tint rear;",
			"\tint *Q;",
			"public:",
			"\tQueue(int size) {",
			"\t\tthis->size = size;",
			"\t\tfront = rear = -1;",
			"\t\tQ = new int[this->size];",
			"\t}",
			"\tvoid enqueue(int x) {",
			"\t\tif (rear == size - 1) cout << \"Queue is Full\" << endl;",
			"\t\telse { rear++; Q[rear] = x; }",
			"\t}",
			"\tint dequeue() {",
			"\t\tint x = -1;",
			"\t\tif (front == rear) cout << \"Queue is Empty\" << endl;",
			"\t\telse { front++; x = Q[front]; }",
			"\t\treturn x;",
			"\t}",
			"\tvoid display() {",
			"\t\tfor (int i = front + 1; i <= rear; i++)",
			"\t\t\tcout << Q[i] << \" \";",
			"\t\tcout << endl;",
			"\t}",
			"};",
