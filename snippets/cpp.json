			"\t\t\ttop = top->next;",
			"\t\t\tx = t->data;",
			"\t\t\tdelete t;",
			"\t\t}",
			"\t\treturn x;",
			"\t}",
			"\tvoid display() {",
			"\t\tNode *p = top;",
			"\t\twhile (p) {",
