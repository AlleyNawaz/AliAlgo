	"stack-infix-postfix": {
		"prefix": "stack-infix-postfix",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Stack {",
			"public:",
			"\tint top; int size; char *S;",
			"\tStack(int sz) { size = sz; top = -1; S = new char[size]; }",
			"\tvoid push(char x) { S[++top] = x; }",
			"\tchar pop() { return S[top--]; }",
			"\tchar stackTop() { return S[top]; }",
			"\tbool isEmpty() { return top == -1; }",
			"};",
			"",
			"int pre(char x) {",
			"\tif (x == '+' || x == '-') return 1;",
			"\tif (x == '*' || x == '/') return 2;",
			"\treturn 0;",
			"}",
			"",
			"bool isOperand(char x) {",
			"\tif (x == '+' || x == '-' || x == '*' || x == '/') return false;",
			"\treturn true;",
			"}",
			"",
			"char* convert(char *infix) {",
			"\tStack st(100);",
			"\tchar *postfix = new char[100];",
			"\tint i = 0, j = 0;",
			"\twhile (infix[i] != '\\0') {",
			"\t\tif (isOperand(infix[i])) postfix[j++] = infix[i++];",
			"\t\telse {",
			"\t\t\tif (st.isEmpty() || pre(infix[i]) > pre(st.stackTop())) st.push(infix[i++]);",
			"\t\t\telse postfix[j++] = st.pop();",
			"\t\t}",
			"\t}",
			"\twhile (!st.isEmpty()) postfix[j++] = st.pop();",
			"\tpostfix[j] = '\\0';",
			"\treturn postfix;",
			"}",
			"",
			"int main() {",
			"\tchar *infix = (char*)\"a+b*c-d/e\";",
			"\tchar *postfix = convert(infix);",
			"\tcout << \"Postfix: \" << postfix << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Infix to Postfix conversion using manual Stack"
	}
