	"ll-insert-pos": {
		"prefix": "ll-insert-pos",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* insertAtPos(Node* head, int val, int pos) {",
			"\tif (pos == 0) {",
			"\t\tNode* newNode = new Node(val);",
			"\t\tnewNode->next = head; return newNode;",
			"\t}",
			"\tNode* temp = head;",
			"\tfor (int i = 0; i < pos - 1 && temp; i++) temp = temp->next;",
			"\tif (!temp) return head;",
			"\tNode* newNode = new Node(val);",
			"\tnewNode->next = temp->next;",
			"\ttemp->next = newNode;",
			"\treturn head;",
			"}",
			"",
			"void printList(Node* head) {",
			"\twhile(head) { cout << head->data << \" \"; head = head->next; }",
			"\tcout << endl;",
			"}",
			"",
			"int main() {",
			"\tNode* head = new Node(10);",
			"\thead->next = new Node(30);",
			"\thead = insertAtPos(head, 20, 1);",
			"\tprintList(head);",
			"\treturn 0;",
			"}"
		],
		"description": "Insert at specific position (Manual)"
