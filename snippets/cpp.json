			"private:",
			"\tint size;",
			"\tint front;",
			"\tint rear;",
			"\tint *Q;",
			"public:",
			"\tCircularQueue(int size) {",
			"\t\tthis->size = size;",
			"\t\tfront = rear = 0;",
			"\t\tQ = new int[this->size];",
			"\t}",
			"\tvoid enqueue(int x) {",
			"\t\tif ((rear + 1) % size == front) cout << \"Queue is Full\" << endl;",
			"\t\telse { rear = (rear + 1) % size; Q[rear] = x; }",
			"\t}",
			"\tint dequeue() {",
			"\t\tint x = -1;",
			"\t\tif (front == rear) cout << \"Queue is Empty\" << endl;",
