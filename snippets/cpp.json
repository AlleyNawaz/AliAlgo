	"array-adt": {
		"prefix": "array-adt",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Array {",
			"private:",
			"\tint *A;",
			"\tint size;",
			"\tint length;",
			"public:",
			"\tArray(int s) {",
			"\t\tsize = s;",
			"\t\tA = new int[size];",
			"\t\tlength = 0;",
			"\t}",
			"\t~Array() {",
			"\t\tdelete[] A;",
			"\t}",
			"\tvoid display() {",
			"\t\tcout << \"Elements are: \";",
			"\t\tfor (int i = 0; i < length; i++)",
			"\t\t\tcout << A[i] << \" \";",
			"\t\tcout << endl;",
			"\t}",
			"\tvoid append(int x) {",
			"\t\tif (length < size)",
			"\t\t\tA[length++] = x;",
			"\t}",
			"\tvoid insert(int index, int x) {",
			"\t\tif (index >= 0 && index <= length && length < size) {",
			"\t\t\tfor (int i = length; i > index; i--)",
			"\t\t\t\tA[i] = A[i - 1];",
			"\t\t\tA[index] = x;",
			"\t\t\tlength++;",
			"\t\t}",
			"\t}",
			"\tint deleteElement(int index) {",
			"\t\tint x = 0;",
			"\t\tif (index >= 0 && index < length) {",
			"\t\t\tx = A[index];",
			"\t\t\tfor (int i = index; i < length - 1; i++)",
			"\t\t\t\tA[i] = A[i + 1];",
			"\t\t\tlength--;",
			"\t\t}",
			"\t\treturn x;",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tArray arr(10);",
			"\tarr.append(10);",
			"\tarr.append(20);",
			"\tarr.insert(1, 15);",
			"\tarr.display();",
			"\tcout << \"Deleted: \" << arr.deleteElement(0) << endl;",
			"\tarr.display();",
			"\treturn 0;",
			"}"
		],
		"description": "Complete Array ADT implementation from scratch"
	},
