			"int main() {",
			"\tNode* head = nullptr;",
			"\thead = insertAtTail(head, 10);",
			"\thead = insertAtTail(head, 20);",
			"\thead = insertAtTail(head, 30);",
			"\tprintList(head);",
			"\treturn 0;",
			"}"
