			"\t\tp = p->next;",
			"\t\tq = q ? q->next : NULL;",
			"\t\tq = q ? q->next : NULL;",
			"\t} while (p && q && p != q);",
			"\treturn p == q;",
			"}",
			"",
			"int main() {",
			"\tNode *first = new Node; first->data = 10;",
			"\tNode *second = new Node; second->data = 20;",
			"\tNode *third = new Node; third->data = 30;",
			"\tfirst->next = second; second->next = third; third->next = first; // Creating loop",
			"\tif (isLoop(first)) cout << \"Loop Detected\" << endl;",
			"\telse cout << \"No Loop\" << endl;",
			"\treturn 0;",
			"}"
		],
