	"ll-simple": {
		"prefix": "ll-simple",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tint data;",
			"\tNode* next;",
			"",
			"\tNode(int val) {",
			"\t\tdata = val;",
			"\t\tnext = NULL;",
			"\t}",
			"};",
			"",
			"class LinkedList {",
			"public:",
			"\tNode* head;",
			"",
			"\tLinkedList() {",
			"\t\thead = NULL;",
			"\t}",
			"",
			"\tvoid insert(int val) {",
			"\t\tNode* newNode = new Node(val);",
			"\t\tif (head == NULL) {",
			"\t\t\thead = newNode;",
			"\t\t\treturn;",
			"\t\t}",
			"\t\tNode* temp = head;",
			"\t\twhile (temp->next != NULL) {",
			"\t\t\ttemp = temp->next;",
			"\t\t}",
			"\t\ttemp->next = newNode;",
			"\t}",
			"",
			"\tvoid display() {",
			"\t\tNode* temp = head;",
			"\t\twhile (temp != NULL) {",
			"\t\t\tcout << temp->data << \" -> \";",
			"\t\t\ttemp = temp->next;",
			"\t\t}",
			"\t\tcout << \"NULL\" << endl;",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tLinkedList list;",
			"\tlist.insert(10);",
			"\tlist.insert(20);",
			"\tlist.insert(30);",
			"\tlist.display();",
			"\treturn 0;",
			"}"
		],
		"description": "Simple Linked List using class"
	},
	"stack-simple": {
		"prefix": "stack-simple",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Stack {",
			"public:",
			"\tint arr[100];",
			"\tint top;",
			"",
			"\tStack() {",
			"\t\ttop = -1;",
			"\t}",
			"",
			"\tvoid push(int val) {",
			"\t\tif (top >= 99) {",
			"\t\t\tcout << \"Stack Overflow\" << endl;",
			"\t\t\treturn;",
			"\t\t}",
			"\t\ttop++;",
			"\t\tarr[top] = val;",
			"\t}",
			"",
			"\tvoid pop() {",
			"\t\tif (top < 0) {",
			"\t\t\tcout << \"Stack Underflow\" << endl;",
			"\t\t\treturn;",
			"\t\t}",
			"\t\ttop--;",
			"\t}",
			"",
			"\tint peek() {",
			"\t\tif (top < 0) return -1;",
			"\t\treturn arr[top];",
			"\t}",
			"",
			"\tbool isEmpty() {",
			"\t\treturn (top < 0);",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tStack s;",
			"\ts.push(10);",
			"\ts.push(20);",
			"\tcout << \"Top element: \" << s.peek() << endl;",
			"\ts.pop();",
			"\tcout << \"Top after pop: \" << s.peek() << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Simple Stack using class and array"
	},
	"queue-simple": {
		"prefix": "queue-simple",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Queue {",
			"public:",
			"\tint arr[100];",
			"\tint front, rear;",
			"",
			"\tQueue() {",
			"\t\tfront = -1;",
			"\t\trear = -1;",
			"\t}",
			"",
			"\tvoid enqueue(int val) {",
			"\t\tif (rear >= 99) {",
			"\t\t\tcout << \"Queue Full\" << endl;",
			"\t\t\treturn;",
			"\t\t}",
			"\t\tif (front == -1) front = 0;",
			"\t\trear++;",
			"\t\tarr[rear] = val;",
			"\t}",
			"",
			"\tvoid dequeue() {",
			"\t\tif (front == -1 || front > rear) {",
			"\t\t\tcout << \"Queue Empty\" << endl;",
			"\t\t\treturn;",
			"\t\t}",
			"\t\tfront++;",
			"\t}",
			"",
			"\tint getFront() {",
			"\t\tif (front == -1 || front > rear) return -1;",
			"\t\treturn arr[front];",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tQueue q;",
			"\tq.enqueue(10);",
			"\tq.enqueue(20);",
			"\tcout << \"Front: \" << q.getFront() << endl;",
			"\tq.dequeue();",
			"\tcout << \"Front after dequeue: \" << q.getFront() << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Simple Queue using class and array"
	},
	"tree-simple": {
		"prefix": "tree-simple",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tint data;",
			"\tNode* left;",
			"\tNode* right;",
			"",
			"\tNode(int val) {",
			"\t\tdata = val;",
			"\t\tleft = NULL;",
			"\t\tright = NULL;",
			"\t}",
			"};",
			"",
			"void inorder(Node* root) {",
			"\tif (root == NULL) return;",
			"\tinorder(root->left);",
			"\tcout << root->data << \" \";",
			"\tinorder(root->right);",
			"}",
			"",
			"int main() {",
			"\tNode* root = new Node(1);",
			"\troot->left = new Node(2);",
			"\troot->right = new Node(3);",
			"\tcout << \"Inorder traversal: \";",
			"\tinorder(root);",
			"\tcout << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Simple Binary Tree using class"
	},
	"sort-bubble-easy": {
		"prefix": "sort-bubble-easy",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"int main() {",
			"\tint arr[] = {5, 2, 8, 1, 9};",
			"\tint n = 5;",
			"",
			"\tfor (int i = 0; i < n - 1; i++) {",
			"\t\tfor (int j = 0; j < n - i - 1; j++) {",
			"\t\t\tif (arr[j] > arr[j + 1]) {",
			"\t\t\t\t// Swap",
			"\t\t\t\tint temp = arr[j];",
			"\t\t\t\tarr[j] = arr[j + 1];",
			"\t\t\t\tarr[j + 1] = temp;",
			"\t\t\t}",
			"\t\t}",
			"\t}",
			"",
			"\tcout << \"Sorted array: \";",
			"\tfor (int i = 0; i < n; i++) cout << arr[i] << \" \";",
			"\treturn 0;",
			"}"
		],
		"description": "Easy Bubble Sort"
	}
