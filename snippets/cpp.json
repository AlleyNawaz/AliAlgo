		"prefix": "graph-dsu-adt",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class DSU {",
			"private:",
			"\tint *parent;",
			"\tint n;",
			"public:",
			"\tDSU(int n) {",
			"\t\tthis->n = n;",
			"\t\tparent = new int[n + 1];",
			"\t\tfor (int i = 1; i <= n; i++) parent[i] = -1;",
			"\t}",
			"\tvoid unionSet(int u, int v) {",
			"\t\tif (parent[u] < parent[v]) {",
			"\t\t\tparent[u] += parent[v];",
			"\t\t\tparent[v] = u;",
			"\t\t} else {",
			"\t\t\tparent[v] += parent[u];",
			"\t\t\tparent[u] = v;",
			"\t\t}",
			"\t}",
			"\tint find(int u) {",
			"\t\tint x = u;",
			"\t\twhile (parent[x] > 0) x = parent[x];",
			"\t\treturn x;",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tDSU ds(5);",
			"\tint u = ds.find(1), v = ds.find(2);",
			"\tif (u != v) ds.unionSet(u, v);",
			"\tcout << \"Union of 1 and 2 completed.\" << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Disjoint Set Union (DSU) from scratch"
	},
	"sort-quick": {
		"prefix": "sort-quick",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"int partition(int A[], int l, int h) {",
			"\tint pivot = A[l], i = l, j = h;",
			"\tdo {",
			"\t\tdo { i++; } while (A[i] <= pivot);",
			"\t\tdo { j--; } while (A[j] > pivot);",
			"\t\tif (i < j) { int temp = A[i]; A[i] = A[j]; A[j] = temp; }",
			"\t} while (i < j);",
			"\tint temp = A[l]; A[l] = A[j]; A[j] = temp;",
			"\treturn j;",
			"}",
			"void quickSort(int A[], int l, int h) {",
			"\tint j;",
			"\tif (l < h) {",
			"\t\tj = partition(A, l, h);",
			"\t\tquickSort(A, l, j);",
			"\t\tquickSort(A, j + 1, h);",
			"\t}",
			"}",
			"",
			"int main() {",
			"\tint A[] = {11, 13, 7, 12, 16, 9, 24, 5, 10, 3, 2147483647}, n = 11;",
			"\tquickSort(A, 0, n - 1);",
			"\tfor (int i = 0; i < n - 1; i++) cout << A[i] << \" \";",
			"\tcout << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Quick Sort implementation from scratch"
	},
