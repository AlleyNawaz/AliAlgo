			"private:",
			"\tNode **HT;",
			"public:",
			"\tHashTable() {",
			"\t\tHT = new Node*[10];",
			"\t\tfor (int i = 0; i < 10; i++) HT[i] = NULL;",
			"\t}",
			"\tint hash(int key) { return key % 10; }",
			"\tvoid insert(int key) {",
			"\t\tint index = hash(key);",
			"\t\tNode *t = new Node; t->data = key; t->next = NULL;",
			"\t\tif (HT[index] == NULL) HT[index] = t;",
			"\t\telse {",
			"\t\t\tNode *p = HT[index], *q = NULL;",
			"\t\t\twhile (p && p->data < key) { q = p; p = p->next; }",
			"\t\t\tif (q == NULL) { t->next = HT[index]; HT[index] = t; }",
			"\t\t\telse { t->next = q->next; q->next = t; }",
			"\t\t}",
			"\t}",
			"\tint search(int key) {",
