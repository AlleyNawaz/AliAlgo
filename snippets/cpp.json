	"ll-insert-tail": {
		"prefix": "ll-insert-tail",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct Node {",
			"\tint data; Node* next;",
			"\tNode(int val) : data(val), next(nullptr) {}",
			"};",
			"",
			"Node* insertAtTail(Node* head, int val) {",
			"\tNode* newNode = new Node(val);",
			"\tif (!head) return newNode;",
			"\tNode* temp = head;",
			"\twhile (temp->next) temp = temp->next;",
			"\ttemp->next = newNode;",
			"\treturn head;",
			"}",
			"",
			"void printList(Node* head) {",
			"\twhile(head) { cout << head->data << \" \"; head = head->next; }",
			"\tcout << endl;",
			"}",
