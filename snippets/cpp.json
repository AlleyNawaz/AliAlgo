	"stack-array": {
		"prefix": "stack-array",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Stack {",
			"\tstatic const int MAX = 1000;",
			"\tint top; int a[MAX];",
			"public:",
			"\tStack() { top = -1; }",
			"\tbool push(int x) { if (top >= (MAX - 1)) return false; a[++top] = x; return true; }",
			"\tint pop() { if (top < 0) return 0; return a[top--]; }",
			"\tint peek() { if (top < 0) return 0; return a[top]; }",
			"\tbool isEmpty() { return top < 0; }",
			"};",
			"",
			"int main() {",
			"\tStack s;",
			"\ts.push(10); s.push(20);",
			"\tcout << s.pop() << \" Popped from stack\" << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Stack implementation using array (Manual)"
	},
	"stack-ll": {
		"prefix": "stack-ll",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct StackNode {",
			"\tint data; StackNode* next;",
			"\tStackNode(int d) : data(d), next(nullptr) {}",
			"};",
			"",
			"class Stack {",
			"\tStackNode* root;",
			"public:",
			"\tStack() : root(nullptr) {}",
			"\tvoid push(int d) { StackNode* node = new StackNode(d); node->next = root; root = node; }",
			"\tint pop() { if(!root) return -1; StackNode* t = root; root = root->next; int d = t->data; delete t; return d; }",
			"\tint peek() { return root ? root->data : -1; }",
			"\tbool isEmpty() { return !root; }",
			"};",
			"",
			"int main() {",
			"\tStack s; s.push(10); s.push(20);",
			"\tcout << s.pop() << \" Popped\" << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Stack using linked list (Manual)"
	},
	"stack-balanced": {
		"prefix": "stack-balanced",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Stack {",
			"\tchar a[100]; int top = -1;",
			"public:",
			"\tvoid push(char x) { a[++top] = x; }",
			"\tvoid pop() { top--; }",
			"\tchar peek() { return a[top]; }",
			"\tbool isEmpty() { return top == -1; }",
			"};",
			"",
			"bool isBalanced(string expr) {",
			"\tStack s;",
			"\tfor (int i=0; i<expr.length(); i++) {",
			"\t\tchar c = expr[i];",
			"\t\tif (c == '(' || c == '[' || c == '{') s.push(c);",
			"\t\telse {",
			"\t\t\tif (s.isEmpty()) return false;",
			"\t\t\tif (c == ')' && s.peek() != '(') return false;",
			"\t\t\tif (c == ']' && s.peek() != '[') return false;",
			"\t\t\tif (c == '}' && s.peek() != '{') return false;",
			"\t\t\ts.pop();",
			"\t\t}",
			"\t}",
			"\treturn s.isEmpty();",
			"}",
			"",
			"int main() {",
			"\tcout << isBalanced(\"(({}))\") << endl; // 1",
			"\tcout << isBalanced(\"({])\") << endl; // 0",
			"\treturn 0;",
			"}"
		],
		"description": "Balanced parentheses checker (Manual Stack)"
	},
	"queue-array": {
		"prefix": "queue-array",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Queue {",
			"\tint front, rear, size, capacity; int* array;",
			"public:",
			"\tQueue(int cap) {",
			"\t\tcapacity = cap; front = size = 0; rear = cap - 1;",
			"\t\tarray = new int[cap];",
			"\t}",
			"\tvoid enqueue(int item) {",
			"\t\tif (size == capacity) return;",
			"\t\trear = (rear + 1) % capacity; array[rear] = item; size++;",
			"\t}",
			"\tint dequeue() {",
			"\t\tif (size == 0) return -1;",
			"\t\tint item = array[front]; front = (front + 1) % capacity; size--; return item;",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tQueue q(10); q.enqueue(10); q.enqueue(20);",
			"\tcout << q.dequeue() << \" Dequeued\" << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Circular array queue (Manual)"
	},
	"queue-ll": {
		"prefix": "queue-ll",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"struct QNode {",
			"\tint data; QNode* next;",
			"\tQNode(int d) : data(d), next(nullptr) {}",
			"};",
			"",
			"class Queue {",
			"\tQNode *front, *rear;",
			"public:",
			"\tQueue() : front(nullptr), rear(nullptr) {}",
			"\tvoid enqueue(int x) {",
			"\t\tQNode* temp = new QNode(x);",
			"\t\tif (!rear) { front = rear = temp; return; }",
			"\t\trear->next = temp; rear = temp;",
			"\t}",
			"\tvoid dequeue() {",
			"\t\tif (!front) return;",
			"\t\tQNode* temp = front; front = front->next;",
			"\t\tif (!front) rear = nullptr; delete temp;",
			"\t}",
			"\tint getFront() { return front ? front->data : -1; }",
			"};",
			"",
			"int main() {",
			"\tQueue q; q.enqueue(10); q.enqueue(20);",
			"\tcout << \"Front: \" << q.getFront() << endl;",
			"\tq.dequeue();",
			"\tcout << \"New Front: \" << q.getFront() << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Queue using linked list (Manual)"
	},
