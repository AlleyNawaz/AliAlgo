	"tree-avl-adt": {
		"prefix": "tree-avl-adt",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tNode *lchild;",
			"\tint data;",
			"\tint height;",
			"\tNode *rchild;",
			"};",
			"",
			"class AVL {",
			"public:",
			"\tNode *root;",
			"\tAVL() { root = NULL; }",
			"\tint nodeHeight(Node *p) {",
			"\t\tint hl, hr;",
			"\t\thl = p && p->lchild ? p->lchild->height : 0;",
			"\t\thr = p && p->rchild ? p->rchild->height : 0;",
			"\t\treturn hl > hr ? hl + 1 : hr + 1;",
			"\t}",
			"\tint balanceFactor(Node *p) {",
			"\t\tint hl, hr;",
			"\t\thl = p && p->lchild ? p->lchild->height : 0;",
			"\t\thr = p && p->rchild ? p->rchild->height : 0;",
			"\t\treturn hl - hr;",
			"\t}",
			"\tNode* LLRotation(Node *p) {",
			"\t\tNode *pl = p->lchild; Node *plr = pl->rchild;",
			"\t\tpl->rchild = p; p->lchild = plr;",
			"\t\tp->height = nodeHeight(p); pl->height = nodeHeight(pl);",
			"\t\tif (root == p) root = pl; return pl;",
			"\t}",
			"\tNode* RRRotation(Node *p) {",
			"\t\tNode *pr = p->rchild; Node *prl = pr->lchild;",
			"\t\tpr->lchild = p; p->rchild = prl;",
			"\t\tp->height = nodeHeight(p); pr->height = nodeHeight(pr);",
			"\t\tif (root == p) root = pr; return pr;",
			"\t}",
			"\tNode* insert(Node *p, int key) {",
			"\t\tNode *t = NULL;",
			"\t\tif (p == NULL) {",
			"\t\t\tt = new Node; t->data = key; t->height = 1; t->lchild = t->rchild = NULL;",
			"\t\t\treturn t;",
			"\t\t}",
			"\t\tif (key < p->data) p->lchild = insert(p->lchild, key);",
			"\t\telse if (key > p->data) p->rchild = insert(p->rchild, key);",
			"\t\tp->height = nodeHeight(p);",
			"\t\tif (balanceFactor(p) == 2 && balanceFactor(p->lchild) == 1) return LLRotation(p);",
			"\t\tif (balanceFactor(p) == -2 && balanceFactor(p->rchild) == -1) return RRRotation(p);",
			"\t\treturn p;",
			"\t}",
			"};",
			"",
			"int main() {",
			"\tAVL tree; tree.root = tree.insert(tree.root, 10);",
			"\ttree.root = tree.insert(tree.root, 20); tree.root = tree.insert(tree.root, 30);",
			"\tcout << \"AVL Root: \" << tree.root->data << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "AVL Tree ADT with rotations from scratch"
	},
