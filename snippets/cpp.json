			"",
			"void merge(int A[], int l, int mid, int h) {",
			"\tint i = l, j = mid + 1, k = l;",
			"\tint B[100];",
			"\twhile (i <= mid && j <= h) {",
			"\t\tif (A[i] < A[j]) B[k++] = A[i++];",
			"\t\telse B[k++] = A[j++];",
			"\t}",
			"\tfor (; i <= mid; i++) B[k++] = A[i++];",
			"\tfor (; j <= h; j++) B[k++] = A[j++];",
			"\tfor (i = l; i <= h; i++) A[i] = B[i];",
			"}",
			"void recursiveMergeSort(int A[], int l, int h) {",
			"\tif (l < h) {",
			"\t\tint mid = (l + h) / 2;",
			"\t\trecursiveMergeSort(A, l, mid);",
			"\t\trecursiveMergeSort(A, mid + 1, h);",
