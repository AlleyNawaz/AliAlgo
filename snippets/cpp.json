			"int binarySearch(int a[], int n, int x) {",
			"\tint l=0, h=n-1; while(l<=h){ int m=l+(h-l)/2; if(a[m]==x) return m; if(a[m]<x) l=m+1; else h=m-1; } return -1;",
			"}",
			"",
			"int main() {",
			"\tint a[] = {2, 3, 4, 10, 40};",
			"\tcout << \"Index of 10: \" << binarySearch(a, 5, 10) << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Iterative binary search (Manual)"
	},
