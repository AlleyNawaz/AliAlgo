	"stack-parenthesis": {
		"prefix": "stack-parenthesis",
		"body": [
			"#include <iostream>",
			"using namespace std;",
			"",
			"class Node {",
			"public:",
			"\tchar data;",
			"\tNode *next;",
			"};",
			"",
			"class Stack {",
			"private:",
			"\tNode *top;",
			"public:",
			"\tStack() { top = NULL; }",
			"\tvoid push(char x) {",
			"\t\tNode *t = new Node;",
			"\t\tif (t == NULL) return;",
			"\t\tt->data = x; t->next = top; top = t;",
			"\t}",
			"\tchar pop() {",
			"\t\tif (top == NULL) return 0;",
			"\t\tNode *t = top; char x = t->data; top = top->next; delete t; return x;",
			"\t}",
			"\tbool isEmpty() { return top == NULL; }",
			"};",
			"",
			"bool isBalanced(char *exp) {",
			"\tStack st;",
			"\tfor (int i = 0; exp[i] != '\\0'; i++) {",
			"\t\tif (exp[i] == '(') st.push('(');",
			"\t\telse if (exp[i] == ')') {",
			"\t\t\tif (st.isEmpty()) return false;",
			"\t\t\tst.pop();",
			"\t\t}",
			"\t}",
			"\treturn st.isEmpty();",
			"}",
			"",
			"int main() {",
			"\tchar *exp = (char*)\"((a+b)*(c-d))\";",
			"\tif (isBalanced(exp)) cout << \"Balanced\" << endl;",
			"\telse cout << \"Not Balanced\" << endl;",
			"\treturn 0;",
			"}"
		],
		"description": "Parenthesis matching using manual Stack"
	},
